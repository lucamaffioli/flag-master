<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" fitToHeight="true" styleClass="backColor" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unipi.applicazione.controller.ResultController">
   <content>
      <StackPane>
         <children>
            <BorderPane styleClass="backColor">
            
               <top>
                  <HBox alignment="CENTER" style="-fx-padding: 30 20 10 20;">
                     <children>
                        <Label text="Game Results" textFill="#333">
                           <font>
                              <Font name="System Bold" size="48.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
               </top>
            
               <center>
                  <StackPane style="-fx-padding: 20;">
                     <children>
                        <VBox alignment="CENTER" maxWidth="1200.0" spacing="25.0">
                           <children>
                              
                              <VBox alignment="CENTER" spacing="5.0">
                                 <children>
                                    <Label fx:id="scoreLabel" text="You got 3 out of 5!" textFill="#2196F3">
                                       <font><Font name="System Bold" size="42.0" /></font>
                                    </Label>
                                    <Label fx:id="percentageLabel" text="Accuracy: 60%" textFill="#555">
                                       <font><Font size="30.0" /></font>
                                    </Label>
                                 </children>
                              </VBox>
            
                              <TableView fx:id="resultsTable" fixedCellSize="120.0" maxWidth="900.0" style="-fx-font-size: 26px; -fx-background-color: white; -fx-border-color: #ccc; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                                 <columns>
                                    <TableColumn fx:id="colFlag" prefWidth="150" style="-fx-alignment: CENTER;" text="Flag" />
                                    <TableColumn fx:id="colUser" prefWidth="300" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 20;" text="Your Answer" />
                                    <TableColumn fx:id="colCorrect" prefWidth="300" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 20;" text="Correct Answer" />
                                    <TableColumn fx:id="colResult" prefWidth="120" style="-fx-alignment: CENTER;" text="Result" />
                                 </columns>
                                 
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>
            
                           </children>
                        </VBox>
                     </children>
                  </StackPane>
               </center>
            
               <bottom>
                  <HBox alignment="CENTER" spacing="40.0" style="-fx-padding: 30;">
                     <children>
                        
                        <Button onAction="#goToPalySelection" prefHeight="80.0" prefWidth="350.0" styleClass="blueButton" text="List Selection" />
                        
                        <Label fx:id="errorLabel" text="" textFill="RED" visible="false" />
                        
                        <Button onAction="#handlePlayAgain" prefHeight="80.0" prefWidth="350.0" styleClass="greenButton" text="Play Again" />
                     
                     </children>
                  </HBox>
               </bottom>
            
            </BorderPane>
         </children>
      </StackPane>
   </content>
</ScrollPane>