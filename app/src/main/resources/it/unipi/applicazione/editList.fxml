<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" fitToHeight="true" styleClass="backColor" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unipi.applicazione.controller.EditListController">
   <content>
      <StackPane>
         <children>
            <BorderPane styleClass="backColor">
            
               <center>
                  <VBox alignment="CENTER" spacing="30.0" style="-fx-padding: 30;">
                     <children>
                        
                        <VBox maxWidth="1200.0" spacing="10.0">
                           <children>
                              <Label text="List Name" textFill="#444">
                                 <font><Font name="System Bold" size="26.0" /></font>
                              </Label>
                              <TextField fx:id="nameField" prefHeight="70.0" promptText="Insert the name.." style="-fx-font-size: 26px; -fx-background-radius: 10; -fx-border-color: #ccc; -fx-border-radius: 10; -fx-padding: 0 20;" />
                           </children>
                        </VBox>
            
                        <HBox alignment="CENTER" maxWidth="1600.0" spacing="80.0" VBox.vgrow="ALWAYS">
                           <children>
                              
                              <VBox prefWidth="450.0" spacing="15.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="Selected Countries" textFill="#4CAF50">
                                       <font><Font name="System Bold" size="24.0" /></font>
                                    </Label>
                                    <ListView fx:id="targetList" fixedCellSize="60.0" style="-fx-font-size: 24px; -fx-border-color: #4CAF50; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS" />
                                 </children>
                              </VBox>
            
                              <VBox alignment="CENTER" minWidth="250.0" spacing="40.0">
                                 <children>
                                    <Button onAction="#handleAddCountry" prefHeight="85.0" prefWidth="220.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" styleClass="blueButton" text="&lt; Add" />
                                    
                                    <Button onAction="#handleRemoveCountry" prefHeight="85.0" prefWidth="220.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" styleClass="redButton" text="Remove &gt;" />
                                 </children>
                              </VBox>
            
                              <VBox prefWidth="550.0" spacing="15.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="Filter by Region" textFill="#666">
                                       <font><Font name="System Bold" size="24.0" /></font>
                                    </Label>
                                    
                                    <ComboBox fx:id="regionCombo" maxWidth="Infinity" prefHeight="60.0" promptText="Select region" style="-fx-font-size: 22px; -fx-background-radius: 10; -fx-border-color: #ccc; -fx-border-radius: 10;" />
            
                                    <Label text="Available Countries" textFill="#333">
                                       <font><Font size="22.0" /></font>
                                    </Label>
                                    
                                    <ListView fx:id="sourceList" fixedCellSize="60.0" style="-fx-font-size: 24px; -fx-border-color: #ccc; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS" />
                                 </children>
                              </VBox>
            
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </center>
            
               <bottom>
                  <VBox spacing="15.0" style="-fx-padding: 30;">
                     <children>
                        <Label fx:id="messageLabel" alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 22px; -fx-font-weight: bold;" textFill="RED" visible="false" />
                        
                        <HBox alignment="CENTER" spacing="30.0">
                           <children>
                              <Button onAction="#handleBack" prefHeight="80.0" prefWidth="350.0" styleClass="blueButton" text="Cancel" />
                           
                              <HBox HBox.hgrow="ALWAYS" />
            
                              <Button onAction="#handleSave" prefHeight="90.0" prefWidth="400.0" styleClass="greenButton" text="SAVE" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </bottom>
            
            </BorderPane>
         </children>
      </StackPane>
   </content>
</ScrollPane>