<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" fitToHeight="true" styleClass="backColor" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unipi.applicazione.controller.GameController">
   <content>
      <StackPane>
         <children>
            <BorderPane styleClass="backColor">
            
               <top>
                  <HBox alignment="CENTER" style="-fx-padding: 30; -fx-background-color: #f8f8f8; -fx-border-color: #ddd; -fx-border-width: 0 0 2 0;">
                     <children>
                        <Label fx:id="progressLabel" text="Question 1 of 5" textFill="#333">
                           <font>
                              <Font name="System Bold" size="32.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
               </top>
            
               <center>
                  <StackPane>
                     <children>
                        <HBox alignment="CENTER" spacing="50.0" style="-fx-padding: 40;">
                           <children>
                              
                              <VBox fx:id="optionsContainer" alignment="CENTER_LEFT" prefWidth="600.0" spacing="35.0">
                                 <children>
                                    <Label text="Which country is this?" textFill="#333">
                                       <font>
                                          <Font name="System Bold" size="36.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets bottom="20.0" />
                                       </VBox.margin>
                                    </Label>
                                    
                                    <RadioButton fx:id="option1" text="Option A" textFill="#222">
                                       <font><Font size="30.0" /></font>
                                       <toggleGroup>
                                          <ToggleGroup fx:id="answersGroup" />
                                       </toggleGroup>
                                       <padding><Insets bottom="15" top="15" /></padding>
                                    </RadioButton>
            
                                    <RadioButton fx:id="option2" text="Option B" textFill="#222" toggleGroup="$answersGroup">
                                       <font><Font size="30.0" /></font>
                                       <padding><Insets bottom="15" top="15" /></padding>
                                    </RadioButton>
            
                                    <RadioButton fx:id="option3" text="Option C" textFill="#222" toggleGroup="$answersGroup">
                                       <font><Font size="30.0" /></font>
                                       <padding><Insets bottom="15" top="15" /></padding>
                                    </RadioButton>
            
                                 </children>
                              </VBox>
            
                              <VBox alignment="CENTER" style="-fx-border-width: 3; -fx-border-radius: 15; -fx-padding: 15;" styleClass="backColor" HBox.hgrow="NEVER">
                                 <ImageView fx:id="flagImage" fitHeight="400.0" fitWidth="600.0" preserveRatio="true" />
                              </VBox>
            
                           </children>
                        </HBox>
                     </children>
                  </StackPane>
               </center>
            
               <bottom>
                  <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 30;">
                     <children>
                        <Label fx:id="errorLabel" style="-fx-font-size: 22px; -fx-font-weight: bold;" textFill="RED" visible="false" />
                        
                        <Button fx:id="nextButton" onAction="#handleNext" prefHeight="100.0" prefWidth="500.0" styleClass="greenButton" text="NEXT QUESTION" />
                     </children>
                  </VBox>
               </bottom>
            
            </BorderPane>
         </children>
      </StackPane>
   </content>
</ScrollPane>