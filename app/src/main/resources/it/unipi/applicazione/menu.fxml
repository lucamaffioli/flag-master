<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" fitToHeight="true" styleClass="backColor" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unipi.applicazione.controller.HomeController">
   <content>
      <StackPane>
         <children>
            <BorderPane styleClass="backColor">
            
               <top>
                  <HBox alignment="CENTER" style="-fx-padding: 10;">
                     <children>
                        <ImageView fitWidth="${vbox.width}" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@img/Logo.png" />
                           </image>
                        </ImageView>
                     </children>
                  </HBox>
               </top>
            
               <center>
                  <StackPane style="-fx-padding: 20;">
                     <children>
                        <VBox fx:id="vbox" alignment="CENTER" maxWidth="800.0" spacing="40.0">
                           <children>
                              
                              <Label fx:id="welcomeLabel" text="Welcome Player" textFill="#333">
                                 <font>
                                    <Font name="System Bold" size="48.0" />
                                 </font>
                              </Label>
                              
                              <Button mnemonicParsing="false" onAction="#switchToLists" prefHeight="90.0" prefWidth="500.0" styleClass="blueButton" text="MY LISTS" />
                              
                              <Button mnemonicParsing="false" onAction="#switchToStatistics" prefHeight="90.0" prefWidth="500.0" styleClass="blueButton" text="STATISTICS" />
                              
                              <Button mnemonicParsing="false" onAction="#switchToStartGame" prefHeight="100.0" prefWidth="500.0" styleClass="greenButton" text="PLAY" />
                           </children>
                        </VBox>
                     </children>
                  </StackPane>
               </center>
            
               <bottom>
                  <VBox alignment="CENTER" spacing="10.0" style="-fx-padding: 30;">
                     <children>
                        
                        <Label fx:id="errorLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;" textFill="RED" visible="false" />
            
                        <HBox fx:id="navBox" alignment="CENTER" spacing="20.0">
                           <children>
                              <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#handleLogout" styleClass="redButton" text="LOGOUT" />
                           </children>
                        </HBox>
                        
                     </children>
                  </VBox>
               </bottom>
            
            </BorderPane>
         </children>
      </StackPane>
   </content>
</ScrollPane>